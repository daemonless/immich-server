#!/bin/sh
# Initialize Immich configuration

# Fix ownership so the unprivileged 'bsd' user can read/write the mounted
# config and media directories. Needed on first run when /data is a freshly
# mounted host directory with foreign ownership.
#
# Chown config/media to 'bsd', but skip the slow recursive pass on large
# libraries when the marker already records the current PUID:PGID (re-chown only
# on first run or a PUID change). Marker written before the chown so it gets
# owned too. SKIP_CHOWN=false forces a chown every start.
SKIP_CHOWN=${SKIP_CHOWN:-true}
WANT="${PUID:-1000}:${PGID:-1000}"

if [ "${SKIP_CHOWN}" = "true" ] && [ "$(cat /config/.chown_done 2>/dev/null)" = "$WANT" ]; then
    echo "Immich server init: ownership already $WANT; skipping permission fix."
else
    echo "Fixing permissions ($WANT)..."
    echo "$WANT" > /config/.chown_done
    chown -R bsd:bsd /config /data /usr/src/app/upload /usr/src/app/library /app 2>/dev/null || true
fi

echo "Immich server initialized."
